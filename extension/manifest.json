{
  "manifest_version": 3,
  "name": "Job Hunt Easy — AI Form Filler",
  "version": "1.0.0",
  "description": "The fastest way to fill job applications and forms using AI. Automatically tailors your answers to the job description.",

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png"
    },
    "default_title": "Fillr — AI Form Filler"
  },

  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "css": [],
      "run_at": "document_idle"
    }
  ],

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "cookies"
  ],

  "_comment_host_permissions": "For production, change http://localhost:3000/* to https://yourdomain.com/*",
  "host_permissions": [
    "https://openrouter.ai/*",
    "http://localhost:3000/*",
    "https://fillr.app/*",
    "https://job-hunt-easy-dashboard.vercel.app/*"
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },

  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
